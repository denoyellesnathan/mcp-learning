{
  "name": "hello-world-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "hello-world-mcp-server": "./src/index.js"
  },
  "scripts": {
    "start": "node src/server/mcp-stdio.js",
    "start:hosted": "node src/server/mcp-streamable-http.js",
    "test:sse": "node test-streamable-http.js",
    "start:wrapper": "node src/server/mcp-rest-wrapper.js",
    "test:openai": "node src/server/openai-mcp-client.js",
    "docker:build": "docker build -t hello-world-mcp-server .",
    "docker:start": "docker run -d -p 3000:3000 --name hello-world-mcp-server hello-world-mcp-server",
    "docker:stop": "docker stop hello-world-mcp-server && docker rm hello-world-mcp-server",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "openai": "^4.0.0",
    "zod": "^3.23.8"
  }
}
