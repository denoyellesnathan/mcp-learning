{
  "name": "hello-world-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "hello-world-mcp-server": "./src/index.js"
  },
  "scripts": {
    "start": "node src/mcp-stdio.js",
    "start:hosted": "node src/mcp-streamable-http.js",
    "test:sse": "node test-streamable-http.js",
    "docker:build": "docker build -t hello-world-mcp-server .",
    "docker:start": "docker run -d -p 3000:3000 --name hello-world-mcp-server hello-world-mcp-server",
    "docker:stop": "docker stop hello-world-mcp-server && docker rm hello-world-mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2"
  }
}
